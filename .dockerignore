.env.local
.env.*.local

# Dev junk
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/

# Git
.git/
.gitignore

# Misc
coverage/
out/
