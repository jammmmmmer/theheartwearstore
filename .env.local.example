# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Printify
PRINTIFY_API_KEY=
PRINTIFY_SHOP_ID=
PRINTIFY_WEBHOOK_SECRET=  # secret configured on the Printify webhook subscription (X-Pfy-Signature verification)

# App
NEXT_PUBLIC_SITE_URL=https://www.theheartwearstore.ca
NEXT_PUBLIC_USD_FX_RATE=0.75  # CAD→USD conversion for USD price display/charging (.99 charm-rounded)
SYNC_SECRET=       # random secret protecting server-to-server endpoints (sync, generate, admin)
APPROVAL_SECRET=   # random secret signing approve/reject email tokens
SESSION_SECRET=    # random secret signing admin login session cookies (falls back to APPROVAL_SECRET if unset)

# Admin login (upload-design page)
UPLOAD_CREDENTIALS=  # format: user1|pass1,user2|pass2 — REQUIRED, login is disabled without it

# Email (approval notifications via Resend)
RESEND_API_KEY=
EMAIL_DOMAIN=
OWNER_EMAIL=

# AI design generation (weekly cron)
GEMINI_API_KEY=
